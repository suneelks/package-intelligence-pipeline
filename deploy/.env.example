# ─── Application DB ──────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=nuget_pipeline

DATABASE_URL=postgresql://postgres:change-me@db:5432/nuget_pipeline

# ─── Dagster system DB (separate logical DB, same server) ────
DAGSTER_PG_HOST=db
DAGSTER_PG_PORT=5432
DAGSTER_PG_USER=postgres
DAGSTER_PG_PASSWORD=change-me
DAGSTER_PG_DB=dagster_storage

# ─── NuGet sync tuning ───────────────────────────────────────
# Concurrency picked from the 2026-04-25 sweep: 20 → 50 → 100 produced
# 72.5 / 71.3 / 61.6 rows/sec. HTTP isn't the bottleneck (sequential per-leaf
# INSERTs are); 50 is the sweet spot until the bulk-insert refactor lands.
NUGET_CONCURRENCY=50
NUGET_PROCESS_BATCH_SIZE=100
# For first-run backfill, set a cap (e.g. 500). Remove/unset once caught up.
NUGET_MAX_PAGES=500

# ─── Enrichment ──────────────────────────────────────────────
# OSS classifier reads from raw.nuget_packages in pages of this size.
# Pure DB work, so larger batches are cheap (~100ms per 1k packages).
OSS_CLASSIFIER_BATCH_SIZE=1000

# SPDX license list (synced into raw.spdx_licenses, ~600 rows). Default
# is the canonical license-list-data repo; pin to a tag for reproducibility.
SPDX_LICENSES_URL=https://raw.githubusercontent.com/spdx/license-list-data/main/json/licenses.json

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=true

# ─── Dagster UI bind address ─────────────────────────────────
# The docker-compose file binds the Dagster UI to this address.
# Leave at 127.0.0.1 to keep it on loopback; set it to a specific
# private interface address to expose the UI only on that network.
DAGSTER_UI_BIND_IP=127.0.0.1
